# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_DIR = os.path.expanduser("~/.cache/vulnsearch")
CACHE_TTL  = 60 * 60 * 24  # 24 hours default


def _cache_key(service: str, version: str, type_key: str | None,
               no_github: bool, no_searchsploit: bool) -> str:
    raw = f"{service}|{version}|{type_key}|{no_github}|{no_searchsploit}"
    return hashlib.sha256(raw.encode()).hexdigest()[:16]


def _cache_path(key: str) -> str:
    os.makedirs(CACHE_DIR, exist_ok=True)
    return os.path.join(CACHE_DIR, f"{key}.json")


def cache_load(key: str, ttl: int) -> list[dict] | None:
    path = _cache_path(key)
    if not os.path.exists(path):
        return None
    age = time.time() - os.path.getmtime(path)
    if age > ttl:
        return None
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return None


def cache_save(key: str, data: list[dict]) -> None:
    try:
        with open(_cache_path(key), "w") as f:
            json.dump(data, f)
    except Exception:
        pass


def results_to_dicts(results: list) -> list[dict]:
    return [
        {k: v for k, v in r.__dict__.items()
         if not k.startswith("_")}
        for r in results
    ]


def dicts_to_results(data: list[dict]) -> list:
    out = []
    for d in data:
        r = Result(
            kind=d.get("kind", "github"),
            title=d.get("title", ""),
            url=d.get("url", ""),
            edb_id=d.get("edb_id", ""),
            ss_type=d.get("ss_type", ""),
            path=d.get("path", ""),
            platform=d.get("platform", ""),
            stars=d.get("stars", 0),
            language=d.get("lang", ""),
            description=d.get("desc", ""),
            updated=d.get("updated", ""),
        )
        out.append(r)
    return out


def cache_clear(service: str = None) -> int:
    """Clear all cache entries, or just those matching a service prefix. Returns count."""
    if not os.path.exists(CACHE_DIR):
        return 0
    removed = 0
    for fname in os.listdir(CACHE_DIR):
        if fname.endswith(".json"):
            fpath = os.path.join(CACHE_DIR, fname)
            # If service given, check the metadata file; otherwise nuke all
            if service:
                try:
                    with open(fpath) as f:
                        data = json.load(f)
                    # cache entries are lists of result dicts; check titles
                    if not any(service.lower() in (d.get("title","") +
                               d.get("desc","")).lower() for d in data):
                        continue
                except Exception:
                    pass
            os.remove(fpath)
            removed += 1
    return removed


